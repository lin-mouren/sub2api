# DO NOT COMMIT REAL VALUES
# Sub2API production-ready environment template

# Core runtime
SERVER_MODE=release
RUN_MODE=standard
TZ=Asia/Shanghai
BIND_HOST=0.0.0.0
SERVER_PORT=8080

# Database (required)
POSTGRES_USER=sub2api
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_RANDOM_SECRET
POSTGRES_DB=sub2api
DATABASE_PORT=5432
DATABASE_MAX_OPEN_CONNS=256
DATABASE_MAX_IDLE_CONNS=128
DATABASE_CONN_MAX_LIFETIME_MINUTES=30
DATABASE_CONN_MAX_IDLE_TIME_MINUTES=5

# Redis (recommended to set password)
REDIS_PASSWORD=REPLACE_WITH_STRONG_RANDOM_SECRET
REDIS_DB=0
REDIS_ENABLE_TLS=false
REDIS_POOL_SIZE=4096
REDIS_MIN_IDLE_CONNS=256

# Admin bootstrap
ADMIN_EMAIL=admin@sub2api.local
ADMIN_PASSWORD=REPLACE_WITH_STRONG_RANDOM_SECRET

# Session/Auth secrets (required, fixed)
JWT_SECRET=REPLACE_WITH_HEX_64_OR_LONG_RANDOM_SECRET
TOTP_ENCRYPTION_KEY=REPLACE_WITH_HEX_64_OR_LONG_RANDOM_SECRET

# Security baseline (required)
SECURITY_URL_ALLOWLIST_ENABLED=true
SECURITY_URL_ALLOWLIST_ALLOW_INSECURE_HTTP=false
SECURITY_URL_ALLOWLIST_ALLOW_PRIVATE_HOSTS=false
SECURITY_URL_ALLOWLIST_UPSTREAM_HOSTS=api.openai.com,api.anthropic.com,generativelanguage.googleapis.com,cloudcode-pa.googleapis.com

# Optional
UPDATE_PROXY_URL=

# Safety fuse (only if RUN_MODE=simple)
SIMPLE_MODE_CONFIRM=false

# Note:
# - Rotate secrets before production go-live.
# - Keep this file as template only; inject real values through secret manager or host env.
