# Sub2API production baseline (example)
# Copy to .env in your deployment directory and fill real secrets.

# Runtime
SERVER_MODE=release
RUN_MODE=standard
TZ=Asia/Shanghai
BIND_HOST=0.0.0.0
SERVER_PORT=8080

# Required strong secrets (replace before deploy)
POSTGRES_USER=sub2api
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_RANDOM_SECRET
POSTGRES_DB=sub2api

JWT_SECRET=REPLACE_WITH_HEX_64_OR_LONG_RANDOM_SECRET
TOTP_ENCRYPTION_KEY=REPLACE_WITH_HEX_64_OR_LONG_RANDOM_SECRET

# Admin bootstrap
ADMIN_EMAIL=admin@sub2api.local
ADMIN_PASSWORD=REPLACE_WITH_STRONG_RANDOM_SECRET

# Redis
REDIS_PASSWORD=REPLACE_WITH_STRONG_RANDOM_SECRET
REDIS_DB=0
REDIS_ENABLE_TLS=false

# Production security baseline
SECURITY_URL_ALLOWLIST_ENABLED=true
SECURITY_URL_ALLOWLIST_ALLOW_INSECURE_HTTP=false
SECURITY_URL_ALLOWLIST_ALLOW_PRIVATE_HOSTS=false

# Narrow to your upstream domains (comma-separated)
SECURITY_URL_ALLOWLIST_UPSTREAM_HOSTS=api.openai.com,api.anthropic.com,generativelanguage.googleapis.com,cloudcode-pa.googleapis.com

# Optional proxy for update/pricing fetch
UPDATE_PROXY_URL=

# Simple mode safety fuse (only if RUN_MODE=simple)
SIMPLE_MODE_CONFIRM=false
